{
  "name": "mymarketingpro-vue",
  "version": "0.2.1",
  "description": "Vue 3 plugin for MyMarketingPro.com",
  "type": "module",
  "main": "./dist/mymarketingpro-vue.cjs",
  "module": "./dist/mymarketingpro-vue.js",
  "exports": {
    ".": {
      "import": "./dist/mymarketingpro-vue.js",
      "require": "./dist/mymarketingpro-vue.cjs"
    },
    "./nuxt": {
      "import": "./dist/nuxt.js",
      "require": "./dist/nuxt.cjs"
    }
  },
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite",
    "prepublishOnly": "vite build",
    "build": "npm run type-check && vite build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint . --ext .vue,.js,.jsx,.cjs,.mjs,.ts,.tsx,.cts,.mts --fix --ignore-path .gitignore",
    "format": "prettier --write src/",
    "type-check": "vue-tsc --build --force"
  },
  "peerDependencies": {
    "vue": "^3.3.0"
  },
  "peerDependenciesMeta": {
    "nuxt": {
      "optional": true
    }
  },
  "devDependencies": {
    "@rushstack/eslint-patch": "^1.16.1",
    "@tsconfig/node20": "^20.1.9",
    "@types/node": "^20.0.0",
    "@vitejs/plugin-vue": "^5.0.0",
    "@vue/eslint-config-prettier": "^9.0.0",
    "@vue/eslint-config-typescript": "^12.0.0",
    "@vue/test-utils": "^2.4.0",
    "@vue/tsconfig": "^0.5.0",
    "eslint": "^8.49.0",
    "eslint-plugin-vue": "^9.17.0",
    "jsdom": "^24.0.0",
    "prettier": "^3.0.0",
    "typescript": "~5.4.0",
    "vite": "^5.0.0",
    "vite-plugin-dts": "^3.7.0",
    "vitest": "^1.0.0",
    "vue": "^3.4.0",
    "vue-tsc": "^2.0.0"
  },
  "keywords": [
    "vue",
    "vue3",
    "nuxt",
    "plugin",
    "mymarketingpro",
    "marketing"
  ],
  "author": "ninjasitm",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ninjasitm/mymarketingpro-vue.git"
  }
}
